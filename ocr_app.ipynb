"""
Arabic OCR Desktop Application
================================
Supports two input modes (auto-detected):
  • Folder of PDF files  → converted to images → OCR → Excel
  • Folder of images     → OCR directly         → Excel

Requirements: See requirements.txt
Run: python ocr_app.py
"""

import os
import re
import threading
import tkinter as tk
from tkinter import filedialog, messagebox, ttk

# Heavy libraries (easyocr, pdf2image, pandas, PIL) are imported lazily
# inside the worker thread so the GUI launches instantly.


# ══════════════════════════════════════════════════════════════════════════════
#  CONSTANTS
# ══════════════════════════════════════════════════════════════════════════════

IMAGE_EXTENSIONS = {".png", ".jpg", ".jpeg", ".bmp", ".tiff", ".tif", ".webp"}
PDF_EXTENSION    = ".pdf"


# ══════════════════════════════════════════════════════════════════════════════
#  EXTRACTION HELPERS
# ══════════════════════════════════════════════════════════════════════════════

def get_value_before(lines: list, keyword: str) -> str:
    """Return the line BEFORE the line containing *keyword* (fallback: line after)."""
    for i, line in enumerate(lines):
        if keyword in line:
            if i > 0:
                return lines[i - 1].strip()
            elif i < len(lines) - 1:
                return lines[i + 1].strip()
    return ""


def parse_birth_info(birth_text: str):
    """Split a birth line into (place, year)."""
    place, year = "", ""
    if birth_text:
        parts = birth_text.split()
        if parts:
            place = parts[0]
        m = re.search(r'\d{4}', birth_text)
        if m:
            year = m.group()
    return place, year


def extract_fields(lines: list) -> dict:
    """Map OCR lines to target Arabic fields via keyword search."""
    birth_text    = get_value_before(lines, "الولادة")
    place, date   = parse_birth_info(birth_text)
    return {
        "الرقم الوطني":     get_value_before(lines, "الرقم"),
        "الاسم":            get_value_before(lines, "الاسم"),
        "النسبة":           get_value_before(lines, "النسبة"),
        "اسم الاب":         get_value_before(lines, "الأب"),
        "اسم الجد":         get_value_before(lines, "الجد"),
        "اسم الام ونسبتها": get_value_before(lines, "الأم"),
        "مكان الولادة":     place,
        "تاريخ الولادة":    date,
    }


# ══════════════════════════════════════════════════════════════════════════════
#  OCR HELPER
# ══════════════════════════════════════════════════════════════════════════════

def ocr_image(image_obj, reader, log_fn, temp_path: str = "temp_ocr_page.png") -> list:
    """
    Enhance a PIL image, save to temp file, run EasyOCR, return text lines.
    *image_obj* can be a PIL Image OR a file path string.
    """
    from PIL import Image, ImageEnhance

    if not hasattr(Image, "ANTIALIAS"):
        Image.ANTIALIAS = Image.Resampling.LANCZOS

    # Load from path if a string was passed
    if isinstance(image_obj, str):
        img = Image.open(image_obj).convert("RGB")
    else:
        img = image_obj.convert("RGB")

    # Contrast enhancement
    img = ImageEnhance.Contrast(img).enhance(1.5)
    img.save(temp_path)

    result = reader.readtext(
        temp_path,
        detail=1,
        paragraph=False,
        text_threshold=0.1,
        low_text=0.2,
        contrast_ths=0.1,
    )

    lines = [det[1].strip() for det in result if det[1].strip()]

    # Clean up temp file
    try:
        os.remove(temp_path)
    except OSError:
        pass

    return lines


# ══════════════════════════════════════════════════════════════════════════════
#  INPUT DISCOVERY
# ══════════════════════════════════════════════════════════════════════════════

def discover_inputs(folder: str):
    """
    Scan *folder* and return (mode, pdfs, images).

    mode = "both"  → folder has PDFs AND images  → process all
    mode = "pdf"   → folder has PDFs only
    mode = "image" → folder has images only
    mode = "empty" → nothing found
    """
    all_files = os.listdir(folder)
    pdfs   = sorted(f for f in all_files if f.lower().endswith(PDF_EXTENSION))
    images = sorted(f for f in all_files
                    if os.path.splitext(f.lower())[1] in IMAGE_EXTENSIONS)

    if pdfs and images:
        return "both", pdfs, images
    if pdfs:
        return "pdf", pdfs, []
    if images:
        return "image", [], images
    return "empty", [], []


