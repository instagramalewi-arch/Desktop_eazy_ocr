import sys
import os

def get_poppler_path() -> str:
    if getattr(sys, "frozen", False):
        # When running as .exe (PyInstaller)
        base = sys._MEIPASS
        return os.path.join(base, "poppler", "bin")
    else:
        # Development — your local poppler path
        return r"C:\Users\ASUS\Downloads\Release-25.12.0-0\poppler-25.12.0\Library\bin"

# ══════════════════════════════════════════════════════════════════════════════
#  PER-FILE PROCESSORS
# ══════════════════════════════════════════════════════════════════════════════

def process_pdf(pdf_path: str, reader, poppler_path, log_fn) -> list:
    """Convert a PDF to images, OCR each page, return list of row dicts."""
    from pdf2image import convert_from_path

    filename = os.path.basename(pdf_path)
    rows     = []

    convert_kwargs = {"pdf_path": pdf_path, "dpi": 300}
    if poppler_path:
        convert_kwargs["poppler_path"] = poppler_path

    try:
        pages = convert_from_path(**convert_kwargs)
    except Exception as exc:
        log_fn(f"  ✗ Cannot convert {filename}: {exc}", error=True)
        return []

    for page_num, page_img in enumerate(pages, start=1):
        label = f"{filename} – page {page_num}"
        log_fn(f"  OCR: {label}")
        try:
            lines = ocr_image(page_img, reader, log_fn)
            row   = {"اسم الملف": filename}
            row.update(extract_fields(lines))
            rows.append(row)
        except Exception as exc:
            log_fn(f"  ✗ OCR failed on {label}: {exc}", error=True)

    return rows


def process_image(image_path: str, reader, log_fn) -> list:
    """OCR a single image file, return a list with one row dict."""
    filename = os.path.basename(image_path)
    log_fn(f"  OCR: {filename}")
    try:
        lines = ocr_image(image_path, reader, log_fn)
        row   = {"اسم الملف": filename}
        row.update(extract_fields(lines))
        return [row]
    except Exception as exc:
        log_fn(f"  ✗ OCR failed on {filename}: {exc}", error=True)
        return []


# ══════════════════════════════════════════════════════════════════════════════
#  MAIN PIPELINE
# ══════════════════════════════════════════════════════════════════════════════

def run_pipeline(input_folder: str, output_folder: str,
                 poppler_path, log_fn, progress_fn, done_fn):
    """
    Auto-detect input type (PDF or image), process all files, save Excel.
    Runs in a background thread.
    """
    try:
        import easyocr
        import pandas as pd
    except ImportError as exc:
        log_fn(f"Missing dependency: {exc}\nRun: pip install {exc.name}", error=True)
        done_fn(success=False)
        return

    # ── Discover inputs ─────────────────────────────────────────────
    mode, pdfs, images = discover_inputs(input_folder)

    if mode == "empty":
        log_fn("No PDF or image files found in the selected folder.", error=True)
        done_fn(success=False)
        return

    # ── Report what was found ─────────────────────────────────────────────
    if mode == "both":
        log_fn(f"📄🖼️  Mixed mode  —  {len(pdfs)} PDF(s)  +  {len(images)} image(s).")
        log_fn("Processing PDFs first, then images…\n")
    elif mode == "pdf":
        log_fn(f"📄 PDF mode  —  {len(pdfs)} PDF file(s).")
        log_fn("Converting PDFs to images then running OCR…\n")
    else:
        log_fn(f"🖼️  Image mode  —  {len(images)} image file(s).")
        log_fn("Running OCR directly on images…\n")

    # ── Initialise EasyOCR (once) ─────────────────────────────────────────────
    log_fn("Loading OCR engine (first run may take a moment)…")
    try:
        reader = easyocr.Reader(['ar'], gpu=False)
    except Exception as exc:
        log_fn(f"Failed to load EasyOCR: {exc}", error=True)
        done_fn(success=False)
        return
    log_fn("OCR engine ready.\n")

    # ── Build unified work list: (filepath, type) ────────────────────────────────────
    # PDFs first, then images — all in one sequential list
    work_list = [(os.path.join(input_folder, f), "pdf")   for f in pdfs] + \
                [(os.path.join(input_folder, f), "image") for f in images]

    # ── Process files ───────────────────────────────────────────────────────────────
    all_rows = []
    total    = len(work_list)

    for idx, (filepath, ftype) in enumerate(work_list, start=1):
        filename = os.path.basename(filepath)
        log_fn(f"[{idx}/{total}] {filename}")

        if ftype == "pdf":
            rows = process_pdf(filepath, reader, poppler_path, log_fn)
        else:
            rows = process_image(filepath, reader, log_fn)

        all_rows.extend(rows)
        progress_fn(idx / total * 100)

    # ── Save Excel ────────────────────────────────────────────────────────────
    if not all_rows:
        log_fn("\nNo data was extracted. Excel file not saved.", error=True)
        done_fn(success=False)
        return

    col_order = [
        "اسم الملف", "الرقم الوطني", "الاسم", "النسبة",
        "اسم الاب", "اسم الجد", "اسم الام ونسبتها",
        "مكان الولادة", "تاريخ الولادة",
    ]
    df          = pd.DataFrame(all_rows, columns=col_order)
    output_path = os.path.join(output_folder, "output.xlsx")

    try:
        df.to_excel(output_path, index=False)
        log_fn(f"\n✓ Done!  {len(all_rows)} record(s) saved to:\n  {output_path}",
               success=True)
        done_fn(success=True, output_path=output_path)
    except Exception as exc:
        log_fn(f"Failed to save Excel file: {exc}", error=True)
        done_fn(success=False)


