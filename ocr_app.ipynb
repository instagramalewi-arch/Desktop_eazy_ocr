    def _make_button(self, parent, text, command, bg, fg="white"):
        btn = tk.Button(parent, text=text, command=command,
                        font=FONT_BTN, bg=bg, fg=fg,
                        activebackground=COLORS["btn_hover"],
                        activeforeground="white",
                        relief="flat", bd=0,
                        padx=18, pady=8, cursor="hand2")
        btn.bind("<Enter>", lambda _: btn.config(bg=COLORS["btn_hover"], fg="white"))
        btn.bind("<Leave>", lambda _: btn.config(bg=bg, fg=fg))
        return btn

    # ── Mode badge ────────────────────────────────────────────────────────────

    def _refresh_mode_badge(self, *_):
        folder = self.input_folder_var.get().strip()
        if not folder or not os.path.isdir(folder):
            self.mode_label_var.set("—")
            self.mode_badge.config(fg=COLORS["muted"])
            return
        mode, pdfs, images = discover_inputs(folder)
        if mode == "both":
            self.mode_label_var.set(f"📄🖼️  Mixed  —  {len(pdfs)} PDF(s) + {len(images)} image(s)")
            self.mode_badge.config(fg=COLORS["accent2"])
        elif mode == "pdf":
            self.mode_label_var.set(f"📄  PDF mode  ({len(pdfs)} file(s))")
            self.mode_badge.config(fg=COLORS["accent2"])
        elif mode == "image":
            self.mode_label_var.set(f"🖼️  Image mode  ({len(images)} file(s))")
            self.mode_badge.config(fg=COLORS["success"])
        else:
            self.mode_label_var.set("⚠️  No PDFs or images found")
            self.mode_badge.config(fg=COLORS["error"])

    # ── Browse callbacks ──────────────────────────────────────────────────────

    def _browse_input(self):
        path = filedialog.askdirectory(title="Select Input Folder (PDFs or Images)")
        if path:
            self.input_folder_var.set(path)

    def _browse_output(self):
        path = filedialog.askdirectory(title="Select Output Folder")
        if path:
            self.output_folder_var.set(path)

    def _browse_poppler(self):
        path = filedialog.askdirectory(title="Select Poppler bin/ Folder")
        if path:
            self.poppler_path_var.set(path)

    # ── Log helpers ───────────────────────────────────────────────────────────

    def _log(self, message: str, error: bool = False, success: bool = False):
        def _append():
            self.log_text.config(state="normal")
            tag = "error" if error else "success" if success else ""
            self.log_text.insert("end", message + "\n", tag)
            self.log_text.see("end")
            self.log_text.config(state="disabled")
        self.after(0, _append)

    def _clear_log(self):
        self.log_text.config(state="normal")
        self.log_text.delete("1.0", "end")
        self.log_text.config(state="disabled")
        self.progress_bar["value"] = 0
        self.progress_label.config(text="Idle")

    def _set_progress(self, value: float):
        def _update():
            self.progress_bar["value"] = value
            self.progress_label.config(text=f"{value:.0f}%")
        self.after(0, _update)

    # ── Start / Done ──────────────────────────────────────────────────────────

    def _start(self):
        if self.is_running:
            return

        input_folder = self.input_folder_var.get().strip()
        if not input_folder or not os.path.isdir(input_folder):
            messagebox.showerror("Error", "Please select a valid Input Folder.")
            return

        # Quick check before launching thread
        mode, pdfs, images = discover_inputs(input_folder)
        if mode == "empty":
            messagebox.showerror("Error",
                                 "No PDF or image files found in the selected folder.")
            return

        # Output folder
        PLACEHOLDER = "Leave blank to use Input Folder"
        raw_out = self.output_folder_var.get().strip()
        if raw_out in ("", PLACEHOLDER):
            output_folder = input_folder
        else:
            os.makedirs(raw_out, exist_ok=True)
            output_folder = raw_out

        poppler_path = self.poppler_path_var.get().strip() or None
        if poppler_path and not os.path.isdir(poppler_path):
            if not messagebox.askyesno(
                    "Poppler path not found",
                    f"The Poppler path does not exist:\n{poppler_path}\n\n"
                    "Continue anyway?"):
                return

        self.is_running = True
        self.start_btn.config(state="disabled", text="⏳  Processing…")
        self.open_btn.config(state="disabled")
        self._clear_log()
        self._log("Starting pipeline…", success=True)
        self._last_output_path = os.path.join(output_folder, "output.xlsx")

        threading.Thread(
            target=run_pipeline,
            args=(input_folder, output_folder, poppler_path,
                  self._log, self._set_progress, self._on_done),
            daemon=True
        ).start()

    def _on_done(self, success: bool = False, output_path: str = ""):
        def _update():
            self.is_running = False
            self.start_btn.config(state="normal", text="▶  Start Processing")
            if success:
                self.open_btn.config(state="normal")
                self._set_progress(100)
        self.after(0, _update)

    def _open_output(self):
        path = getattr(self, "_last_output_path", "")
        if path and os.path.isfile(path):
            import subprocess, platform
            if platform.system() == "Windows":
                os.startfile(path)
            elif platform.system() == "Darwin":
                subprocess.call(["open", path])
            else:
                subprocess.call(["xdg-open", path])
        else:
            messagebox.showinfo("Not Found", "Output file not found yet.")

    # ── Utility ───────────────────────────────────────────────────────────────

    def _center_window(self, w: int, h: int):
        self.update_idletasks()
        sw = self.winfo_screenwidth()
        sh = self.winfo_screenheight()
        self.geometry(f"{w}x{h}+{(sw-w)//2}+{(sh-h)//2}")


