    # ── Row builders ──────────────────────────────────────────────────────────

    def _build_folder_row(self, parent, label_text, var,
                          command, required=False, placeholder=""):
        row = tk.Frame(parent, bg=COLORS["bg"], pady=5)
        row.pack(fill="x")

        tk.Label(row, text=label_text, font=FONT_BOLD,
                 bg=COLORS["bg"], fg=COLORS["text"],
                 width=22, anchor="w").pack(side="left")

        entry = tk.Entry(
            row, textvariable=var, font=FONT_LABEL,
            bg=COLORS["panel"],
            fg=COLORS["text"] if not placeholder else COLORS["muted"],
            insertbackground=COLORS["accent"], relief="flat", bd=6,
            highlightthickness=1, highlightbackground=COLORS["border"],
            highlightcolor=COLORS["accent"])
        entry.pack(side="left", fill="x", expand=True, padx=(0, 8))

        if placeholder and not var.get():
            entry.insert(0, placeholder)
            entry.config(fg=COLORS["muted"])

            def _focus_in(_e, e=entry):
                if e.get() == placeholder:
                    e.delete(0, "end")
                    e.config(fg=COLORS["text"])

            def _focus_out(_e, e=entry):
                if not e.get():
                    e.insert(0, placeholder)
                    e.config(fg=COLORS["muted"])

            entry.bind("<FocusIn>",  _focus_in)
            entry.bind("<FocusOut>", _focus_out)

        tk.Button(row, text="Browse…", command=command,
                  font=FONT_LABEL, bg=COLORS["border"],
                  fg=COLORS["text"], relief="flat",
                  activebackground=COLORS["accent"],
                  activeforeground="white",
                  padx=10, pady=4, cursor="hand2").pack(side="left")

        if required:
            tk.Label(row, text="*", font=FONT_BOLD,
                     bg=COLORS["bg"], fg=COLORS["error"]).pack(side="left", padx=2)

